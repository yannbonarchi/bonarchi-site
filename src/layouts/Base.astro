---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, altPaths } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  /** Open Graph type — "website" for pages, "article" for posts */
  type?: 'website' | 'article';
  /** Social share image, resolved against the site origin. */
  image?: string;
  /** ISO date — emits article:published_time for posts. */
  publishedTime?: string;
  /** JSON-LD structured data — one object or an array. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Software engineer who goes deep into a domain and builds the systems it needs. Right now that is banking, in Central Africa. Notes on building software, fintech, and the road from engineering to leadership.',
  type = 'website',
  image = '/og.png',
  publishedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
const siteName = 'Bonarchi SIMEU';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const ldBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const lang = getLangFromUrl(Astro.url);
const { en: enPath, fr: frPath } = altPaths(Astro.url.pathname);
const enHref = new URL(enPath, Astro.site).href;
const frHref = new URL(frPath, Astro.site).href;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Language detection: from the bare EN root only, redirect French-preferring
         visitors to /fr. An explicit switch (data-set-lang) is remembered and wins. -->
    <script is:inline>
      (function () {
        try {
          if (location.pathname === '/') {
            var pref = localStorage.getItem('lang');
            var lang =
              pref ||
              ((navigator.language || '').toLowerCase().slice(0, 2) === 'fr'
                ? 'fr'
                : 'en');
            if (lang === 'fr') location.replace('/fr/');
          }
        } catch (e) {}
      })();
      addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('[data-set-lang]');
        if (a) {
          try {
            localStorage.setItem('lang', a.getAttribute('data-set-lang'));
          } catch (_) {}
        }
      });
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <meta name="google-site-verification" content="XokgB8Jr6W_Tc4jh32rgfhgNW5Z1T_t-44IwaqcpjyQ" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph / social -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
      <meta property="article:author" content={siteName} />
    )}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />

    {ldBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
