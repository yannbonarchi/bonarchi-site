---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="This page does not exist.">
  <section class="wrap nf">
    <span class="ledger-no">404</span>
    <h1>This entry isn't in the ledger.</h1>
    <p class="lede">The page you're looking for doesn't exist, or has moved.</p>
    <p class="nf-links">
      <a href="/">Home</a>
      <span class="sep">·</span>
      <a href="/writing">Writing</a>
      <span class="sep">·</span>
      <a href="/work">Work</a>
    </p>
  </section>
</Base>

<style>
  .nf { padding-top: 3rem; max-width: 44rem; }
  .lede { font-size: 1.2rem; color: var(--ink-soft); }
  .nf-links {
    font-family: var(--mono);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .nf-links .sep { color: var(--ink-faint); margin: 0 0.6rem; }
</style>
