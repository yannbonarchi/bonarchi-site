---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base title="Contact" description="Get in touch with Bonarchi SIMEU.">
  <article class="wrap prose">
    <span class="ledger-no">00</span>
    <h1>Contact</h1>
    <p class="lede">
      Working on something at the intersection of software and the real world?
      Send a note. I read everything; I reply to most.
    </p>

    <ContactForm lang="en" />

    <p class="alt">
      Prefer to skip the form? <a href="mailto:bonarchisimeu@gmail.com">Email</a>
      · <a href="https://www.linkedin.com/in/bonarchisimeu">LinkedIn</a>
      · <a href="https://github.com/bonarchisimeu">GitHub</a>
    </p>
  </article>
</Base>

<style>
  .prose { padding-top: 2.5rem; max-width: 44rem; }
  .lede { font-size: 1.2rem; color: var(--ink-soft); }
  .alt { margin-top: 2rem; font-size: 0.9rem; color: var(--ink-faint); }
</style>
