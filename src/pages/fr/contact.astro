---
import Base from '../../layouts/Base.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Base title="Contact" description="Entrer en contact avec Bonarchi SIMEU.">
  <article class="wrap prose">
    <span class="ledger-no">00</span>
    <h1>Contact</h1>
    <p class="lede">
      Un projet à l'intersection du logiciel et du réel ? Laissez un mot. Je lis
      tout ; je réponds à presque tout.
    </p>

    <ContactForm lang="fr" />

    <p class="alt">
      Vous préférez éviter le formulaire ? <a href="mailto:bonarchisimeu@gmail.com">E-mail</a>
      · <a href="https://www.linkedin.com/in/bonarchisimeu">LinkedIn</a>
      · <a href="https://github.com/bonarchisimeu">GitHub</a>
    </p>
  </article>
</Base>

<style>
  .prose { padding-top: 2.5rem; max-width: 44rem; }
  .lede { font-size: 1.2rem; color: var(--ink-soft); }
  .alt { margin-top: 2rem; font-size: 0.9rem; color: var(--ink-faint); }
</style>
