---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const work = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (
  await getCollection('writing', ({ data }) => !data.draft && data.lang === 'fr')
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' });

const focus = [
  {
    no: '01',
    title: 'Plonger dans un domaine',
    body: "Je ne livre pas du logiciel générique. J'apprends le terrain jusqu'à savoir construire ce dont il a vraiment besoin. La banque aujourd'hui ; la méthode voyage vers la suite.",
  },
  {
    no: '02',
    title: 'Des systèmes qui doivent être justes',
    body: "Quand le résultat, c'est de l'argent réel, un diagnostic ou une récolte, juste l'emporte sur malin. Je construis pour ce qui ne peut pas échouer en silence.",
  },
  {
    no: '03',
    title: "De l'ingénierie au leadership",
    body: "Pourquoi construire des systèmes est le meilleur apprentissage pour construire des équipes et des entreprises. La trajectoire que je suis, écrite au fil de l'eau.",
  },
];

const topics = [
  'Mobile money',
  'Core banking',
  'Réglementation CEMAC / BEAC',
  'ZLECAf & paiements transfrontaliers',
  'Architecture système',
  'Ingénierie → leadership',
];

const origin = Astro.site?.origin ?? 'https://bonarchisimeu.me';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Bonarchi SIMEU',
    url: origin,
    jobTitle: 'Ingénieur logiciel',
    description:
      "Ingénieur logiciel qui construit les systèmes dont un domaine a besoin. Actuellement dans la banque et la fintech, en Afrique centrale.",
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Yaoundé',
      addressCountry: 'CM',
    },
    sameAs: [
      'https://github.com/bonarchisimeu',
      'https://www.linkedin.com/in/bonarchisimeu',
    ],
  },
];
---

<Base
  title="Bonarchi SIMEU"
  description="Je plonge dans un domaine et je construis le logiciel qui le fait tourner. Aujourd'hui, la banque en Afrique centrale. Notes sur le logiciel, la fintech, et le chemin de l'ingénierie vers le leadership."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero wrap">
    <div class="hero-text">
      <p class="eyebrow">Ingénieur logiciel · Yaoundé, Cameroun</p>
      <h1>J'apprends un domaine, puis je construis le logiciel qui le fait tourner.</h1>
      <p class="lede">
        Aujourd'hui ce domaine, c'est la banque, dans la zone CEMAC : systèmes
        core, et le pont entre comptes bancaires et portefeuilles mobile money,
        la tuyauterie qui déplace l'argent réel. Demain, ce sera peut-être
        l'énergie, la santé, l'agriculture. Le domaine change. Le métier voyage.
      </p>
      <p class="hero-cta">
        <a href="/fr/work">Voir les réalisations</a>
        <span class="sep">·</span>
        <a href="/fr/writing">Lire les écrits</a>
      </p>
    </div>

    <aside class="card" aria-label="En bref">
      <div class="card-head">
        <span class="meta">Le Carnet</span>
        <span class="meta">No. 001</span>
      </div>
      <div class="double-rule"></div>
      <p class="card-name">Bonarchi SIMEU</p>
      <p class="card-role">Ingénieur logiciel · concepteur de systèmes</p>
      <dl class="card-rows">
        <div><dt class="meta">Basé à</dt><dd>Yaoundé, Cameroun</dd></div>
        <div><dt class="meta">Région</dt><dd>CEMAC · Afrique centrale</dd></div>
        <div><dt class="meta">Formation</dt><dd>Master · Génie logiciel</dd></div>
        <div><dt class="meta">Statut</dt><dd><span class="open">Ouvert aux échanges</span></dd></div>
      </dl>
    </aside>
  </section>

  <!-- FOCUS -->
  <section class="wrap block">
    <header class="block-head">
      <span class="ledger-no">§</span>
      <h2>Sur quoi je travaille</h2>
    </header>
    <div class="focus-grid">
      {focus.map((f) => (
        <article class="focus">
          <span class="ledger-no">{f.no}</span>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- WORK -->
  <section class="wrap block">
    <header class="block-head">
      <span class="ledger-no">01</span>
      <h2>Réalisations</h2>
      <a class="more" href="/fr/work">Toutes les études de cas →</a>
    </header>
    {work.length === 0 ? (
      <div class="placeholder">
        <p>Les études de cas sont en cours de rédaction, anonymisées là où elles
        touchent des systèmes confidentiels. En attendant, voici le type de
        travail qu'elles couvrent :</p>
        <ul class="chips">
          <li>Intégration mobile money ↔ core banking</li>
          <li>Migration de grand livre sans interruption</li>
          <li>Réconciliation &amp; idempotence à l'échelle</li>
        </ul>
      </div>
    ) : (
      <ul class="entry-list">
        {work.map((w) => (
          <li>
            <a href={`/work/${w.id}`} class="entry">
              <span class="entry-title">{w.data.title}</span>
              <span class="entry-summary">{w.data.summary}</span>
              {w.data.year && <span class="meta entry-year">{w.data.year}</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- WRITING -->
  <section class="wrap block">
    <header class="block-head">
      <span class="ledger-no">02</span>
      <h2>Écrits</h2>
      <a class="more" href="/fr/writing">Toutes les notes →</a>
    </header>
    {posts.length === 0 ? (
      <div class="placeholder">
        <p>Les premières notes arrivent. Ce sur quoi j'écris :</p>
        <ul class="chips">
          {topics.map((tp) => <li>{tp}</li>)}
        </ul>
      </div>
    ) : (
      <ul class="entry-list">
        {posts.map((p) => (
          <li>
            <a href={`/fr/writing/${p.data.urlSlug}`} class="entry">
              <span class="entry-title">{p.data.title}</span>
              <span class="entry-summary">{p.data.description}</span>
              <span class="meta entry-year">{fmt(p.data.pubDate)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- CTA -->
  <section class="wrap cta">
    <div class="double-rule"></div>
    <div class="cta-inner">
      <h2>Vous construisez quelque chose à l'intersection de la banque et du logiciel en Afrique ?</h2>
      <p>J'échange toujours volontiers, sur les systèmes, la fintech ou la région.</p>
      <p class="cta-links">
        <a href="mailto:bonarchisimeu@gmail.com">Écrivez-moi</a>
        <span class="sep">·</span>
        <a href="/fr/about">En savoir plus</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: 2.5rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .hero-text { min-width: 0; }
  .lede { font-size: 1.2rem; line-height: 2.5rem; color: var(--ink-soft); max-width: 48ch; }
  .hero-cta { font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .hero-cta .sep { color: var(--ink-faint); margin: 0 0.75rem; }

  .card { background: var(--paper-2); border: 1px solid var(--rule-strong); padding: 1.25rem 1.5rem 1.5rem; align-self: start; }
  .card-head { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
  .card-name { font-family: var(--display); font-size: 1.3rem; font-weight: 600; margin: 1rem 0 0.1rem; }
  .card-role { color: var(--ink-soft); font-size: 0.9rem; margin: 0 0 1rem; }
  .card-rows { margin: 0; }
  .card-rows > div { display: flex; justify-content: space-between; gap: 1rem; padding: 0.4rem 0; border-top: 1px dotted var(--rule); }
  .card-rows dt { margin: 0; }
  .card-rows dd { margin: 0; font-size: 0.9rem; text-align: right; }
  .open { color: var(--accent); }

  .block { margin-block: clamp(3rem, 7vw, 5rem); }
  .block-head { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.75rem; border-bottom: 1px solid var(--rule); padding-bottom: 0.5rem; }
  .block-head h2 { margin: 0; }
  .block-head .more { margin-left: auto; font-family: var(--mono); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; }

  .focus-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; }
  .focus h3 { margin: 0.5rem 0 0.5rem; font-size: 1.2rem; }
  .focus p { color: var(--ink-soft); font-size: 0.95rem; margin: 0; max-width: 38ch; }

  .entry-list { list-style: none; margin: 0; padding: 0; max-width: none; }
  .entry { display: grid; grid-template-columns: 1fr auto; gap: 0.25rem 1.5rem; padding: 1.25rem 0; border-bottom: 1px solid var(--rule); color: var(--ink); text-decoration: none; }
  .entry:hover { color: var(--ink); }
  .entry:hover .entry-title { color: var(--accent); }
  .entry-title { font-family: var(--display); font-size: 1.35rem; font-weight: 540; line-height: 1.2; }
  .entry-summary { grid-column: 1; color: var(--ink-soft); font-size: 0.95rem; max-width: 60ch; }
  .entry-year { grid-column: 2; grid-row: 1; align-self: start; padding-top: 0.4rem; }

  .placeholder p { color: var(--ink-soft); }
  .chips { list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-wrap: wrap; gap: 0.6rem; max-width: none; }
  .chips li { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.02em; color: var(--ink-soft); background: var(--paper-2); border: 1px solid var(--rule); padding: 0.35rem 0.7rem; border-radius: 3px; }

  .cta { margin-top: clamp(3rem, 7vw, 5rem); }
  .cta-inner { padding-top: 1.5rem; max-width: 44rem; }
  .cta-inner h2 { font-size: clamp(1.4rem, 3vw, 2rem); }
  .cta-inner p { color: var(--ink-soft); }
  .cta-links { font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.5rem; }
  .cta-links .sep { color: var(--ink-faint); margin: 0 0.75rem; }

  @media (max-width: 720px) {
    .hero { grid-template-columns: 1fr; }
    .card { order: 2; }
  }
</style>
