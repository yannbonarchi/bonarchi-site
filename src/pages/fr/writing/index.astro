---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (
  await getCollection('writing', ({ data }) => !data.draft && data.lang === 'fr')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Écrits" description="Notes sur la fintech, le mobile money, le core banking, et le chemin de l'ingénierie vers le leadership — écrites depuis l'Afrique centrale.">
  <section class="wrap">
    <span class="ledger-no">§</span>
    <h1>Écrits</h1>
    <p class="lede">
      Notes de l'intérieur de la fintech d'Afrique centrale. Mobile money, core
      banking, réglementation, et ce que l'ingénierie apprend sur le leadership.
    </p>
    {posts.length === 0 ? (
      <p class="empty">Les premières notes arrivent bientôt.</p>
    ) : (
      <ul class="posts">
        {posts.map((p) => (
          <li>
            <a href={`/fr/writing/${p.data.urlSlug}`} class="post">
              <time class="meta" datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
              <h2>{p.data.title}</h2>
              <p>{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>

<style>
  .wrap { padding-top: 2.5rem; }
  .lede { font-size: 1.2rem; color: var(--ink-soft); max-width: 52ch; }
  .note { font-family: var(--label); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-faint); }
  .empty { color: var(--ink-faint); font-style: italic; }
  .posts { list-style: none; padding: 0; margin-top: var(--space); max-width: none; }
  .post { display: block; padding: 1.5rem 0; border-top: 1px solid var(--rule); color: var(--ink); text-decoration: none; }
  .post:hover { color: var(--ink); }
  .post:hover h2 { color: var(--accent); }
  .post h2 { margin: 0.4rem 0 0.5rem; }
  .post p { color: var(--ink-soft); margin: 0; max-width: 60ch; }
</style>
