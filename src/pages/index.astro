---
import Base from '../layouts/Base.astro';
import Home from '../components/Home.astro';

const origin = Astro.site?.origin ?? 'https://bonarchisimeu.me';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Bonarchi SIMEU',
    givenName: 'Yann',
    additionalName: 'Bonarchi',
    familyName: 'Simeu Kenmoue',
    alternateName: [
      'Yann Bonarchi Simeu Kenmoue',
      'Yann Bonarchi Simeu',
      'Yann Simeu',
      'Bonarchi Simeu',
    ],
    url: origin,
    jobTitle: 'Software Engineer',
    description:
      'Software engineer who builds the systems a domain needs. Currently working in banking and fintech in Central Africa.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Yaoundé',
      addressCountry: 'CM',
    },
    knowsAbout: [
      'Software engineering',
      'Systems design',
      'Banking software',
      'Mobile money',
      'Fintech',
    ],
    sameAs: [
      'https://github.com/bonarchisimeu',
      'https://www.linkedin.com/in/bonarchisimeu',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Bonarchi SIMEU',
    url: origin,
  },
];
---

<Base title="Bonarchi SIMEU" jsonLd={jsonLd}>
  <Home lang="en" />
</Base>
