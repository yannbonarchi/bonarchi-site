---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection(
    'writing',
    ({ data }) => !data.draft && data.lang === 'en',
  );
  return posts.map((post) => ({ params: { slug: post.data.urlSlug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { data } = post;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const origin = Astro.site?.origin ?? 'https://bonarchisimeu.me';
const url = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updated ?? data.pubDate).toISOString(),
  url,
  mainEntityOfPage: url,
  author: { '@type': 'Person', name: 'Bonarchi SIMEU', url: origin },
  publisher: { '@type': 'Person', name: 'Bonarchi SIMEU', url: origin },
  keywords: data.tags.join(', '),
};
---

<Base
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={data.pubDate.toISOString()}
  jsonLd={jsonLd}
>
  <article class="wrap prose">
    <a class="back" href="/writing">← Writing</a>
    <time class="meta" datetime={data.pubDate.toISOString()}>{fmt(data.pubDate)}</time>
    <h1>{data.title}</h1>
    {data.tags.length > 0 && (
      <p class="tags">
        {data.tags.map((t) => <span class="tag">#{t}</span>)}
      </p>
    )}
    <div class="double-rule rule-sp"></div>
    <Content />
    {data.updated && (
      <p class="updated meta">Updated {fmt(data.updated)}</p>
    )}
  </article>
</Base>

<style>
  .prose { padding-top: 2rem; max-width: 48rem; }
  /* article body: bigger, more readable type that fills the column */
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote) {
    max-width: none;
    font-size: 1.2rem;
    line-height: 1.75;
  }
  .prose :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-top: 2.75rem;
  }
  .back {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  h1 { margin-top: 0.5rem; font-size: clamp(2.2rem, 5vw, 3.2rem); }
  .tags { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .tag {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .rule-sp { margin: 1.5rem 0 var(--space); }
  .updated { margin-top: var(--space); }
</style>
